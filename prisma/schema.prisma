generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum Foot {
  RIGHT
  LEFT
  BOTH
}

enum CardRarity {
  STANDARD
  FEATURED
  POTW
  HIGHLIGHT
  TRENDING
  LEGEND
  EPIC
  BIG_TIME
  SHOW_TIME
  SPECIAL
}

enum SkillCategory {
  FINISHING
  DRIBBLING
  PASSING
  DEFENDING
  PHYSICAL
  GOALKEEPING
  GENERAL
}

enum CardAbilityType {
  NATIVE
  RECOMMENDED
  USER_ADDED
}

enum BuildObjective {
  COMPETITIVE
  MAX_OVERALL
  FINISHER
  CREATOR
  DRIBBLER
  PRESSING
  POSSESSION
  QUICK_COUNTER
  DEFENSIVE
  AERIAL
}

enum DataSourceKind {
  AUTHORIZED_JSON_FEED
  AUTHORIZED_API
  USER_UPLOAD
  PARTNER_LICENSE
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role                @default(USER)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  squads             Squad[]
  builds             Build[]
  recommendationLogs RecommendationLog[]
}

model Player {
  id                 String      @id @default(cuid())
  externalId         String?     @unique
  name               String
  club               String?
  country            String?
  mainPosition       String
  secondaryPositions String?
  playstyle          String?
  height             Int?
  weight             Int?
  age                Int?
  dominantFoot       Foot        @default(RIGHT)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  cards              Card[]
  squadSlots         SquadSlot[]
  externalMaps       ExternalPlayerMap[]

  @@index([name])
  @@index([mainPosition])
  @@index([club])
  @@index([playstyle])
}

model Card {
  id          String          @id @default(cuid())
  playerId    String
  player      Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  name        String
  season      String?
  rarity      CardRarity      @default(STANDARD)
  overall     Int
  maxOverall  Int?
  playstyle   String?
  imageUrl    String?
  positions   String?
  releaseDate DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  attributes  CardAttribute?
  abilities   CardAbility[]
  builds      Build[]
  squadSlots  SquadSlot[]
  externalMaps ExternalCardMap[]

  @@index([overall])
  @@index([maxOverall])
  @@index([rarity])
  @@index([name])
}

model CardAttribute {
  id                     String   @id @default(cuid())
  cardId                 String   @unique
  card                   Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  offensiveAwareness     Int      @default(70)
  ballControl            Int      @default(70)
  dribbling              Int      @default(70)
  tightPossession        Int      @default(70)
  lowPass                Int      @default(70)
  loftedPass             Int      @default(70)
  finishing              Int      @default(70)
  heading                Int      @default(70)
  placeKicking           Int      @default(70)
  curl                   Int      @default(70)
  speed                  Int      @default(70)
  acceleration           Int      @default(70)
  kickingPower           Int      @default(70)
  jump                   Int      @default(70)
  physicalContact        Int      @default(70)
  balance                Int      @default(70)
  stamina                Int      @default(70)
  defensiveAwareness     Int      @default(50)
  tackling               Int      @default(50)
  aggression             Int      @default(50)
  defensiveEngagement    Int      @default(50)
  goalkeeperAwareness    Int      @default(40)
  goalkeeperCatching     Int      @default(40)
  goalkeeperParrying     Int      @default(40)
  goalkeeperReflexes     Int      @default(40)
  goalkeeperReach        Int      @default(40)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Ability {
  id             String           @id @default(cuid())
  name           String           @unique
  category       SkillCategory    @default(GENERAL)
  description    String?
  finishingBoost Int              @default(0)
  creationBoost  Int              @default(0)
  dribbleBoost   Int              @default(0)
  defenseBoost   Int              @default(0)
  mobilityBoost  Int              @default(0)
  physicalBoost  Int              @default(0)
  pressureBoost  Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  cards          CardAbility[]
}

model CardAbility {
  id        String          @id @default(cuid())
  cardId    String
  card      Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  abilityId String
  ability   Ability         @relation(fields: [abilityId], references: [id], onDelete: Cascade)
  type      CardAbilityType @default(NATIVE)
  createdAt DateTime        @default(now())

  @@unique([cardId, abilityId, type])
  @@index([type])
}

model Build {
  id                String         @id @default(cuid())
  cardId            String
  card              Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  name              String
  objective         BuildObjective @default(COMPETITIVE)
  targetPosition    String
  shooting          Int            @default(0)
  passing           Int            @default(0)
  dribbling         Int            @default(0)
  dexterity         Int            @default(0)
  lowerBodyStrength Int            @default(0)
  aerialStrength    Int            @default(0)
  defending         Int            @default(0)
  gk1               Int            @default(0)
  gk2               Int            @default(0)
  gk3               Int            @default(0)
  priOverall        Float          @default(0)
  scores            Json
  recommendedSkills String?
  tacticalFit       Json?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([objective])
  @@index([targetPosition])
}

model Squad {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  formation String      @default("4-2-2-2")
  style     String      @default("Quick Counter")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  slots     SquadSlot[]
}

model SquadSlot {
  id        String   @id @default(cuid())
  squadId   String
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  position  String
  x         Int      @default(50)
  y         Int      @default(50)
  playerId  String?
  player    Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  cardId    String?
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecommendationLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  input     Json
  result    Json
  createdAt DateTime @default(now())
}

model DataSource {
  id                    String          @id @default(cuid())
  name                  String          @unique
  kind                  DataSourceKind  @default(AUTHORIZED_JSON_FEED)
  baseUrl               String?
  documentationUrl      String?
  enabled               Boolean         @default(true)
  termsAcceptedByUserAt DateTime?
  lastSyncedAt          DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  syncJobs              SyncJob[]
  cardMaps              ExternalCardMap[]
  playerMaps            ExternalPlayerMap[]
}

model SyncJob {
  id          String        @id @default(cuid())
  sourceId    String
  source      DataSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status      SyncJobStatus @default(QUEUED)
  startedAt   DateTime?
  finishedAt  DateTime?
  totalRows   Int           @default(0)
  createdRows Int           @default(0)
  updatedRows Int           @default(0)
  skippedRows Int           @default(0)
  error       String?
  createdAt   DateTime      @default(now())

  @@index([status])
  @@index([createdAt])
}

model ExternalPlayerMap {
  id         String     @id @default(cuid())
  sourceId   String
  source     DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId String
  playerId   String
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  raw         Json?
  rawHash     String?
  syncedAt   DateTime   @default(now())

  @@unique([sourceId, externalId])
  @@index([playerId])
}

model ExternalCardMap {
  id         String     @id @default(cuid())
  sourceId   String
  source     DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId String
  cardId     String
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  raw         Json?
  rawHash     String?
  syncedAt   DateTime   @default(now())

  @@unique([sourceId, externalId])
  @@index([cardId])
}
