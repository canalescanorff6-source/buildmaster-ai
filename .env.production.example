# BuildMaster AI — produção na Vercel/Render + Neon PostgreSQL

# Cole aqui a string do banco Neon/PostgreSQL.
# Exemplo real vem do painel do Neon.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# Gere uma chave longa e segura. Pode usar: openssl rand -base64 48
JWT_SECRET="troque_por_uma_chave_com_mais_de_32_caracteres"

NEXT_PUBLIC_APP_NAME="BuildMaster AI"

# Opcional: usado apenas se você configurar atualização automática por feed autorizado.
AUTHORIZED_CARDS_FEED_URL=""
AUTHORIZED_CARDS_FEED_TOKEN=""
SYNC_SOURCE_NAME="Minha Fonte Autorizada"
CRON_SECRET="troque_por_um_token_longo_para_cron"
